# Sanity public read-only credentials
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Supabase frontend auth (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Meta Pixel (frontend)
VITE_META_PIXEL_ID=

# API CORS
CORS_ALLOW_ORIGIN=http://localhost:5173

# Sanity server-side credentials for Vercel functions
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=
SANITY_API_VERSION=2024-06-01

# Razorpay server-side credentials
RAZORPAY_KEY_ID=
RAZORPAY_SECRET_KEY=

# Admin API auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=8h

# Frontend to Admin API (optional override)
VITE_ADMIN_API_BASE_URL=/api/admin

# Cloudflare Worker integration (server-side only)
WORKER_API_BASE_URL=https://lecture-video-manager.<subdomain>.workers.dev
WORKER_AUTH_KEY_SECRET=

# Cloudflare R2 secure playback (server-side only)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Supabase server/admin auth (server-side only)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PASSWORD_SETUP_REDIRECT=
SUPABASE_SITE_URL=
